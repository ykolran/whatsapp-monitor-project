# LM Studio API (leave as-is if using default LM Studio port)
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODEL=local-model
LM_STUDIO_TOKEN=my-token

# Server config
PORT=3000
HOST=0.0.0.0

# Auth token (set a random string; configure same value in Android app)
AUTH_TOKEN=change-me-to-a-random-secret

# Face recognition threshold (lower = stricter matching, 0.0–1.0)
FACE_MATCH_THRESHOLD=0.5

# Path to Python executable (for face recognition)
PYTHON_PATH=python
