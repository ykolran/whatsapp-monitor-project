# LM Studio
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODEL=local-model
LM_STUDIO_API_TOKEN=your-lmstudio-token

# Server
PORT=3000
HOST=0.0.0.0

# Admin token — used only for /admin/users to create/delete users
ADMIN_TOKEN=change-this-admin-secret

# Face recognition threshold (0.0 strict – 1.0 loose)
FACE_MATCH_THRESHOLD=0.5

# Python executable path
PYTHON_PATH=python
